# Copy this file to .streamlit/secrets.toml and fill in your credentials.
# secrets.toml is gitignored — never commit it.

[tradier]
api_key     = "your-tradier-api-key-here"
account_id  = "your-account-id-here"
# "sandbox" uses paper.tradier.com; "live" uses api.tradier.com
env         = "sandbox"

MASSIVE_API_KEY = "your_massive_api_key_here"
